[build]           if [ -z "$$EVG_HOST_ADDRESS" ]; then
[build]             echo "ERROR: EVG_HOST_ADDRESS is empty." >&2
[build]             echo "Either run make switch (auto-resolves from .generated/.current-evg-host)" >&2
[build]             echo "or set EVG_HOST_ADDRESS as a sidecar env in compose.user.yml." >&2
[build]             exit 1
[build]           fi
[build]           echo "evg-host-proxy: waiting for ssh-agent socket at $$SSH_AUTH_SOCK..."
[build]           until [ -S "$$SSH_AUTH_SOCK" ]; do sleep 1; done
[build]           echo "evg-host-proxy: ssh-agent ready; starting autossh to ubuntu@$$EVG_HOST_ADDRESS"
[build]           exec autossh -M 0 -N \
[build]             -o "ServerAliveInterval 30" \
[build]             -o "ServerAliveCountMax 3" \
[build]             -D 0.0.0.0:1080 \
[build]             ubuntu@$$EVG_HOST_ADDRESS
