[build]           exec autossh -M 0 -N \
[build]             -o "ServerAliveInterval 30" \
[build]             -o "ServerAliveCountMax 3" \
[build]             -D 0.0.0.0:1080 \
[build]             ubuntu@$$EVG_HOST_ADDRESS
[build]     environment:
[build]       SSH_AUTH_SOCK: /ssh-agent/socket
[build]     networks:
[build]       devcontainer: null
[build]     restart: unless-stopped
[build]     volumes:
[build]       - type: bind
[build]         source: /Users/lukasz.sierant/mdb/lsierant_KUBE-26-background-tester/.generated
[build]         target: /generated
[build]         read_only: true
[build]         bind: {}
[build]       - type: volume
[build]         source: ssh-auth-sock
[build]         target: /ssh-agent
[build]         volume: {}
[build]       - type: bind
[build]         source: /Users/lukasz.sierant/.ssh/known_hosts
[build]         target: /etc/ssh/ssh_known_hosts
[build]         read_only: true
[build]         bind: {}
[build]   gost-proxy:
[build]     command:
[build]       - -L
[build]       - http://:8080
[build]       - -F
[build]       - socks5://evg-host-proxy:1080
[build]     depends_on:
[build]       evg-host-proxy:
[build]         condition: service_started
[build]         required: true
[build]     image: gogost/gost
[build]     networks:
[build]       devcontainer: null
[build]     ports:
[build]       - mode: ingress
[build]         host_ip: 127.0.0.1
[build]         target: 8080
[build]         published: "8000"
[build]         protocol: tcp
[build]   k8s-proxy:
[build]     cap_add:
[build]       - NET_ADMIN
[build]     command:
