[build]       dockerfile: autossh.Dockerfile
[build]     command:
[build]       - bash
[build]       - -c
[build]       - |
[build] 
[build]           set -Eeo pipefail
[build]           echo "evg-host-proxy: starting..."
[build]           # EVG_HOST_ADDRESS may be passed via compose env (e.g. compose.user.yml
[build]           # override). Otherwise fall back to the auto-resolved cache file.
[build]           # ($$ escapes the dollar so compose passes the variable name through to bash.)
[build]           if [ -z "$$EVG_HOST_ADDRESS" ] && [ -s /generated/.current-evg-host-address ]; then
[build]             EVG_HOST_ADDRESS=$$(cat /generated/.current-evg-host-address)
