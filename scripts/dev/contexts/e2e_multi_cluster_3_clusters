#!/usr/bin/env bash

set -Eeou pipefail

script_name=$(readlink -f "${BASH_SOURCE[0]}")
script_dir=$(dirname "${script_name}")

source "${script_dir}/root-context"

# 3-cluster topology used by simulated multi-cluster MongoDBSearch tests:
#   - kind-e2e-operator: hosts the central MC operator (reconciles MongoDB cross-cluster RS only)
#   - kind-e2e-cluster-1: member cluster (mongod members + a simulated-MC search operator)
#   - kind-e2e-cluster-2: member cluster (mongod members + a simulated-MC search operator)
export KUBE_ENVIRONMENT_NAME=multi
export CLUSTER_NAME="kind-e2e-operator"
export MEMBER_CLUSTERS="kind-e2e-cluster-1 kind-e2e-cluster-2"
export CENTRAL_CLUSTER=kind-e2e-operator
export TEST_POD_CLUSTER=kind-e2e-cluster-1
export test_pod_cluster=kind-e2e-cluster-1
export ops_manager_version="cloud_qa"
export OPERATOR_NAME="mongodb-kubernetes-operator-multi-cluster"
