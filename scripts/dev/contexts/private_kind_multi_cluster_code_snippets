#!/usr/bin/env bash

# this context file is for multi-cluster code snippets running on kind clusters
set -Eeou pipefail

# overrides of public env_variables.sh
script_name=$(readlink -f "${BASH_SOURCE[0]}")
script_dir=$(dirname "${script_name}")

source "${script_dir}/root-context"
# 2-cluster kind environment: KUBE_ENVIRONMENT_NAME=multi makes
# setup_kubernetes_environment provision the interconnected kind clusters
# (CENTRAL_CLUSTER / MEMBER_CLUSTERS) with an Istio mesh.
source "${script_dir}/e2e_multi_cluster_2_clusters"

export NAMESPACE=mongodb
export CODE_SNIPPETS_FLAVOR=e2e_private
