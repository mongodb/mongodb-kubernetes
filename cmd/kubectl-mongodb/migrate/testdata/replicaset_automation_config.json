{
  "auth": {
    "usersWanted": [
      {
        "user": "mms-automation-agent",
        "db": "admin",
        "roles": [{"role": "root", "db": "admin"}],
        "mechanisms": ["SCRAM-SHA-256"],
        "scramSha256Creds": {"iterationCount": 15000, "salt": "abc", "serverKey": "skey", "storedKey": "stkey"},
        "scramSha1Creds": null,
        "authenticationRestrictions": []
      },
      {
        "user": "app-user",
        "db": "admin",
        "roles": [
          {"role": "readWrite", "db": "myapp"},
          {"role": "read", "db": "reporting"}
        ],
        "mechanisms": ["SCRAM-SHA-256"],
        "scramSha256Creds": {"iterationCount": 15000, "salt": "def", "serverKey": "skey2", "storedKey": "stkey2"},
        "scramSha1Creds": null,
        "authenticationRestrictions": []
      },
      {
        "user": "CN=x509-client,O=MongoDB",
        "db": "$external",
        "roles": [
          {"role": "readWrite", "db": "secure-db"}
        ],
        "mechanisms": [],
        "scramSha256Creds": null,
        "scramSha1Creds": null,
        "authenticationRestrictions": []
      },
      {
        "user": "ldap-reader",
        "db": "$external",
        "roles": [
          {"role": "read", "db": "reporting"}
        ],
        "mechanisms": [],
        "scramSha256Creds": null,
        "scramSha1Creds": null,
        "authenticationRestrictions": []
      }
    ],
    "usersDeleted": [],
    "disabled": false,
    "authoritativeSet": false,
    "deploymentAuthMechanisms": ["SCRAM-SHA-256", "MONGODB-X509", "PLAIN"],
    "autoAuthMechanisms": ["SCRAM-SHA-256"],
    "autoAuthMechanism": "SCRAM-SHA-256",
    "autoUser": "mms-automation-agent",
    "autoAuthRestrictions": []
  },
  "ldap": {
    "bindMethod": "simple",
    "bindQueryUser": "cn=admin,dc=example,dc=com",
    "bindQueryPassword": "ldap-s3cret",
    "servers": "ldap1.example.com:636, ldap2.example.com:636",
    "transportSecurity": "tls",
    "validateLDAPServerConfig": true,
    "authzQueryTemplate": "{USER}?memberOf?base",
    "userToDNMapping": "[{\"match\":\"(.+)\",\"substitution\":\"uid={0},ou=users,dc=example,dc=com\"}]",
    "timeoutMS": 10000,
    "userCacheInvalidationInterval": 30,
    "CAFileContents": "-----BEGIN CERTIFICATE-----\nMIIBxTCCAWugAwIBAgIUFakeCAContentsForTesting=\n-----END CERTIFICATE-----"
  },
  "oidcProviderConfigs": [
    {
      "authNamePrefix": "okta",
      "audience": "api://mongodb-cluster",
      "issuerUri": "https://dev-123456.okta.com/oauth2/default",
      "clientId": "0oa1abc2def3ghi4j567",
      "requestedScopes": ["openid", "profile", "groups"],
      "userClaim": "sub",
      "groupsClaim": "groups",
      "supportsHumanFlows": true,
      "useAuthorizationClaim": true
    }
  ],
  "processes": [
    {
      "args2_6": {
        "net": {
          "port": 27017,
          "tls": {
            "PEMKeyFile": "/mongodb-automation/server.pem",
            "mode": "requireSSL"
          }
        },
        "replication": {
          "replSetName": "my-rs",
          "oplogSizeMB": 2048
        },
        "security": {
          "clusterAuthMode": "x509"
        },
        "storage": {
          "dbPath": "/data/db",
          "wiredTiger": {
            "engineConfig": {
              "cacheSizeGB": 1.5
            }
          }
        },
        "systemLog": {
          "destination": "file",
          "path": "/var/log/mongodb/mongod.log"
        },
        "setParameter": {
          "authenticationMechanisms": "SCRAM-SHA-256,PLAIN"
        }
      },
      "authSchemaVersion": 5,
      "featureCompatibilityVersion": "7.0",
      "hostname": "vm-mongo-0.prod.example.com",
      "logRotate": {
        "sizeThresholdMB": 1000,
        "timeThresholdHrs": 24,
        "numUncompressed": 5
      },
      "auditLogRotate": {
        "sizeThresholdMB": 500,
        "timeThresholdHrs": 48
      },
      "name": "my-rs-0",
      "processType": "mongod",
      "version": "7.0.12-ent"
    },
    {
      "args2_6": {
        "net": {
          "port": 27017,
          "tls": {
            "PEMKeyFile": "/mongodb-automation/server.pem",
            "mode": "requireSSL"
          }
        },
        "replication": {
          "replSetName": "my-rs",
          "oplogSizeMB": 2048
        },
        "security": {
          "clusterAuthMode": "x509"
        },
        "storage": {
          "dbPath": "/data/db",
          "wiredTiger": {
            "engineConfig": {
              "cacheSizeGB": 1.5
            }
          }
        },
        "systemLog": {
          "destination": "file",
          "path": "/var/log/mongodb/mongod.log"
        },
        "setParameter": {
          "authenticationMechanisms": "SCRAM-SHA-256,PLAIN"
        }
      },
      "authSchemaVersion": 5,
      "featureCompatibilityVersion": "7.0",
      "hostname": "vm-mongo-1.prod.example.com",
      "name": "my-rs-1",
      "processType": "mongod",
      "version": "7.0.12-ent"
    },
    {
      "args2_6": {
        "net": {
          "port": 27017,
          "tls": {
            "PEMKeyFile": "/mongodb-automation/server.pem",
            "mode": "requireSSL"
          }
        },
        "replication": {
          "replSetName": "my-rs",
          "oplogSizeMB": 2048
        },
        "security": {
          "clusterAuthMode": "x509"
        },
        "storage": {
          "dbPath": "/data/db",
          "wiredTiger": {
            "engineConfig": {
              "cacheSizeGB": 1.5
            }
          }
        },
        "systemLog": {
          "destination": "file",
          "path": "/var/log/mongodb/mongod.log"
        },
        "setParameter": {
          "authenticationMechanisms": "SCRAM-SHA-256,PLAIN"
        }
      },
      "authSchemaVersion": 5,
      "featureCompatibilityVersion": "7.0",
      "hostname": "vm-mongo-2.prod.example.com",
      "name": "my-rs-2",
      "processType": "mongod",
      "version": "7.0.12-ent"
    }
  ],
  "replicaSets": [
    {
      "_id": "my-rs",
      "members": [
        {
          "_id": 0,
          "host": "my-rs-0",
          "priority": 2,
          "votes": 1,
          "tags": {"region": "us-east-1", "use": "analytics"},
          "horizons": {
            "external": "rs0.external.example.com:27017",
            "internal": "rs0.internal.example.com:27017"
          }
        },
        {
          "_id": 1,
          "host": "my-rs-1",
          "priority": 1,
          "votes": 1,
          "tags": {"region": "us-west-2"},
          "horizons": {
            "external": "rs1.external.example.com:27017",
            "internal": "rs1.internal.example.com:27017"
          }
        },
        {
          "_id": 2,
          "host": "my-rs-2",
          "priority": 1,
          "votes": 1,
          "horizons": {
            "external": "rs2.external.example.com:27017",
            "internal": "rs2.internal.example.com:27017"
          }
