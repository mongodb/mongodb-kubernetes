      "protocolVersion": "1"
    }
  ],
  "sharding": [],
  "tls": {
    "CAFilePath": "/mongodb-automation/tls/ca/ca-pem",
    "clientCertificateMode": "OPTIONAL"
  },
  "mongoDbVersions": [],
  "monitoringVersions": [],
  "backupVersions": [],
  "options": {
    "downloadBase": "/var/lib/mongodb-mms-automation"
  },
  "roles": [
    {
      "role": "appReadOnly",
      "db": "myapp",
      "privileges": [
        {
          "actions": ["find", "listCollections"],
          "resource": {"db": "myapp", "collection": ""}
        }
      ],
      "roles": [
        {"role": "read", "db": "myapp"}
      ]
    }
  ]
