    },
    {
      "args2_6": {
        "net": {"port": 27017},
        "systemLog": {"destination": "file", "path": "/var/log/mongodb/mongos.log"}
      },
      "featureCompatibilityVersion": "8.0",
      "hostname": "mongos-0.example.com",
      "name": "ldap-mongos-0",
      "processType": "mongos",
      "version": "8.0.4-ent"
    }
  ],
  "replicaSets": [
    {
      "_id": "ldap-shard-rs",
      "members": [
        {"_id": 0, "host": "ldap-shard-rs-0", "priority": 1, "votes": 1, "tags": {}},
        {"_id": 1, "host": "ldap-shard-rs-1", "priority": 1, "votes": 1, "tags": {}}
      ],
      "protocolVersion": "1"
    },
    {
      "_id": "ldap-csrs",
      "members": [
        {"_id": 0, "host": "ldap-csrs-0", "priority": 1, "votes": 1, "tags": {}},
        {"_id": 1, "host": "ldap-csrs-1", "priority": 1, "votes": 1, "tags": {}}
      ],
      "protocolVersion": "1"
    }
  ],
  "roles": [],
  "sharding": [
    {
      "_id": "ldap-cluster",
      "name": "ldap-cluster",
      "configServerReplica": "ldap-csrs",
      "shards": [
        {"_id": "ldap-shard", "rs": "ldap-shard-rs"}
      ]
    }
  ],
  "version": 1
