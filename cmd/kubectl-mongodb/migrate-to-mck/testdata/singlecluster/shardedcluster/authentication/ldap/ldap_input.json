{
  "auth": {
    "usersWanted": [
      {
        "user": "uid=mms-automation-agent,ou=groups,dc=example,dc=org",
        "db": "$external",
        "roles": [{"role": "root", "db": "admin"}],
        "mechanisms": [],
        "scramSha256Creds": null,
        "scramSha1Creds": null,
        "authenticationRestrictions": []
      },
      {
        "user": "uid=vm-app-user,dc=example,dc=org",
        "db": "$external",
        "roles": [
          {"role": "readWrite", "db": "myapp"}
        ],
        "mechanisms": [],
        "scramSha256Creds": null,
        "scramSha1Creds": null,
        "authenticationRestrictions": []
      }
    ],
    "usersDeleted": [],
    "disabled": false,
    "authoritativeSet": false,
    "deploymentAuthMechanisms": ["SCRAM-SHA-256", "PLAIN"],
    "autoAuthMechanisms": ["PLAIN"],
    "autoAuthMechanism": "PLAIN",
    "autoUser": "uid=mms-automation-agent,ou=groups,dc=example,dc=org",
    "autoPwd": "agent-ldap-password",
    "autoAuthRestrictions": [],
    "key": "dGVzdC1rZXlmaWxlLWNvbnRlbnQ=",
    "keyfile": "/var/lib/mongodb-mms-automation/keyfile",
    "keyfileWindows": "%SystemDrive%\\MMSAutomation\\versions\\keyfile"
  },
  "ldap": {
    "servers": "openldap.mongodb.svc.cluster.local:389",
    "bindMethod": "simple",
    "bindQueryUser": "cn=admin,dc=example,dc=org",
    "bindQueryPassword": "ldap-admin-password",
    "transportSecurity": "none",
    "validateLDAPServerConfig": true
  },
  "options": {
    "downloadBase": "/var/lib/mongodb-mms-automation"
  },
  "processes": [
    {
      "args2_6": {
        "net": {"port": 27018, "tls": {"mode": "disabled"}},
        "replication": {"replSetName": "ldap-shard-rs"},
        "sharding": {"clusterRole": "shardsvr"},
        "storage": {"dbPath": "/data/shard"},
        "systemLog": {"destination": "file", "path": "/var/log/mongodb/mongod.log"}
      },
      "authSchemaVersion": 5,
      "featureCompatibilityVersion": "8.0",
      "hostname": "shard-0.example.com",
      "name": "ldap-shard-rs-0",
      "processType": "mongod",
      "version": "8.0.4-ent"
    },
    {
      "args2_6": {
        "net": {"port": 27018, "tls": {"mode": "disabled"}},
        "replication": {"replSetName": "ldap-shard-rs"},
        "sharding": {"clusterRole": "shardsvr"},
        "storage": {"dbPath": "/data/shard"},
        "systemLog": {"destination": "file", "path": "/var/log/mongodb/mongod.log"}
      },
      "authSchemaVersion": 5,
      "featureCompatibilityVersion": "8.0",
      "hostname": "shard-1.example.com",
      "name": "ldap-shard-rs-1",
      "processType": "mongod",
      "version": "8.0.4-ent"
    },
    {
      "args2_6": {
        "net": {"port": 27019, "tls": {"mode": "disabled"}},
        "replication": {"replSetName": "ldap-csrs"},
        "sharding": {"clusterRole": "configsvr"},
        "storage": {"dbPath": "/data/config"},
        "systemLog": {"destination": "file", "path": "/var/log/mongodb/mongod.log"}
      },
      "authSchemaVersion": 5,
      "featureCompatibilityVersion": "8.0",
      "hostname": "config-0.example.com",
      "name": "ldap-csrs-0",
      "processType": "mongod",
      "version": "8.0.4-ent"
    },
    {
      "args2_6": {
        "net": {"port": 27019, "tls": {"mode": "disabled"}},
        "replication": {"replSetName": "ldap-csrs"},
        "sharding": {"clusterRole": "configsvr"},
        "storage": {"dbPath": "/data/config"},
        "systemLog": {"destination": "file", "path": "/var/log/mongodb/mongod.log"}
      },
      "authSchemaVersion": 5,
      "featureCompatibilityVersion": "8.0",
      "hostname": "config-1.example.com",
      "name": "ldap-csrs-1",
